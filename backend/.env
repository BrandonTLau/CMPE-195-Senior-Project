PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/notescan_db
JWT_SECRET=dev_jwt_secret_change_in_production
JWT_EXPIRES=10h
FRONTEND_URL=http://localhost:5173
 
# LLM settings
LLM_ENGINE=ollama
LLM_MODEL=gemma3:1b
LLM_API_URL=http://127.0.0.1:11434
 
# Chandra OCR — Datalab hosted API
# Get your free API key at: https://www.datalab.to/app/keys
CHANDRA_API_KEY= <your_datalab_api_key_here>
CHANDRA_MODE=fast
CHANDRA_TIMEOUT_SECONDS=120
